			"content": "<script lang=\"ts\">\r\n\timport { CollapsibleTrigger } from \"$COMPONENTS$/ui/collapsible\";\r\n\timport { cn } from \"$UTILS$\";\r\n\timport ChevronDown from \"@lucide/svelte/icons/chevron-down\";\r\n\r\n\timport type { Snippet } from \"svelte\";\r\n\r\n\tlet {\r\n\t\tclass: className,\r\n\t\tleftIcon,\r\n\t\tswapIconOnHover = true,\r\n\t\tchildren\r\n\t}: {\r\n\t\tclass?: string;\r\n\t\tleftIcon?: Snippet;\r\n\t\tswapIconOnHover?: boolean;\r\n\t\tchildren?: Snippet;\r\n\t} = $props();\r\n</script>\r\n\r\n<CollapsibleTrigger\r\n\tclass={cn(\r\n\t\t\"group flex w-full cursor-pointer items-center justify-start gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground\",\r\n\t\tclassName\r\n\t)}\r\n>\r\n\t<div class=\"flex items-center gap-2\">\r\n\t\t{#if leftIcon}\r\n\t\t\t<span\r\n\t\t\t\tclass=\"relative inline-flex size-4 items-center justify-center\"\r\n\t\t\t>\r\n\t\t\t\t<span\r\n\t\t\t\t\tclass={cn(\r\n\t\t\t\t\t\t\"transition-opacity\",\r\n\t\t\t\t\t\tswapIconOnHover && \"group-hover:opacity-0\"\r\n\t\t\t\t\t)}\r\n\t\t\t\t>\r\n\t\t\t\t\t{@render leftIcon()}\r\n\t\t\t\t</span>\r\n\t\t\t\t{#if swapIconOnHover}\r\n\t\t\t\t\t<ChevronDown\r\n\t\t\t\t\t\tclass=\"absolute size-4 opacity-0 transition-opacity group-hover:opacity-100 group-data-[state=open]:rotate-180\"\r\n\t\t\t\t\t/>\r\n\t\t\t\t{/if}\r\n\t\t\t</span>\r\n\t\t{/if}\r\n\t\t{#if children}\r\n\t\t\t<span>{@render children()}</span>\r\n\t\t{/if}\r\n\t</div>\r\n\t{#if !leftIcon}\r\n\t\t<ChevronDown\r\n\t\t\tclass=\"size-4 transition-transform group-data-[state=open]:rotate-180\"\r\n\t\t/>\r\n\t{/if}\r\n</CollapsibleTrigger>\r\n",
			"type": "registry:component",
			"target": "ai/steps/steps-trigger.svelte"
		},
		{
			"content": "import Steps from \"./steps.svelte\";\r\nimport StepsBar from \"./steps-bar.svelte\";\r\nimport StepsContent from \"./steps-content.svelte\";\r\nimport StepsItem from \"./steps-item.svelte\";\r\nimport StepsTrigger from \"./steps-trigger.svelte\";\r\n\r\nexport {\r\n    Steps,\r\n    StepsBar,\r\n    StepsContent,\r\n    StepsItem,\r\n    StepsTrigger,\r\n    Steps as Root,\r\n    StepsBar as Bar,\r\n    StepsContent as Content,\r\n    StepsItem as Item,\r\n    StepsTrigger as Trigger\r\n};",
