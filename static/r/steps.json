			"content": "<script lang=\"ts\">\r\n\timport { Collapsible } from \"$COMPONENTS$/ui/collapsible\";\r\n\timport { cn } from \"$UTILS$\";\r\n\timport type { Snippet } from \"svelte\";\r\n\r\n\tlet {\r\n\t\tdefaultOpen = true,\r\n\t\topen = $bindable(defaultOpen),\r\n\t\tclass: className,\r\n\t\tchildren\r\n\t}: {\r\n\t\tdefaultOpen?: boolean;\r\n\t\topen?: boolean;\r\n\t\tclass?: string;\r\n\t\tchildren?: Snippet;\r\n\t} = $props();\r\n</script>\r\n\r\n<Collapsible bind:open class={cn(className)}>\r\n\t{#if children}\r\n\t\t{@render children()}\r\n\t{/if}\r\n</Collapsible>\r\n",
